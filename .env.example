# OCR provider: "gemini" | "ollama" | "colab". UI can override per request.
OCR_PROVIDER=gemini
# Set false to use Ollama only (no Gemini fallback on OCR failure)
OCR_FALLBACK_TO_GEMINI=false

# Gemini (required when OCR_PROVIDER=gemini or when UI selects Gemini)
GEMINI_API_KEY="MY_GEMINI_API_KEY"
GEMINI_MODEL=gemini-3.5-flash

# Ollama (required when OCR_PROVIDER=ollama or when UI selects Ollama)
# Run: ollama serve && ollama pull moondream
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=moondream
OLLAMA_TIMEOUT_MS=420000

# Colab GPU OCR (run test.ipynb in Colab + ngrok; paste public URL here)
COLAB_OCR_URL=
COLAB_OCR_SECRET=
COLAB_OCR_MODEL=moondream
COLAB_OCR_TIMEOUT_MS=600000

# RAG — Chroma (local) + LLM provider
# RAG_PROVIDER: "ollama" (Colab GPU via COLAB_OCR_URL) or "gemini" (cloud)
RAG_PROVIDER=ollama
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_SSL=false
CHROMA_COLLECTION=ocr_document_chunks
RAG_EMBEDDING_MODEL=nomic-embed-text
RAG_CHAT_MODEL=llama3.2:3b
RAG_TIMEOUT_MS=600000
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
RAG_TOP_K=5
# Only if RAG_PROVIDER=gemini:
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"
